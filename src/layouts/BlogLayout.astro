---
import "../styles/global.css";
const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{frontmatter.title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <main
            class="max-w-screen min-h-screen bg-black text-white flex justify-center"
        >
            <div class="w-3/4 py-10 flex flex-col gap-y-3">
                <h1 class="text-5xl font-semibold">{frontmatter.title}</h1>
                <p class="text-gray-200 text-lg">{frontmatter.description}</p>
                <div class="flex items-center gap-x-3">
                    <span class="font-extrabold text-gray-400"
                        >{frontmatter.time}</span
                    >
                    <span class="font-extrabold">·</span>
                    <span class="font-extrabold text-gray-400">
                        {frontmatter.pubDate}</span
                    >
                </div>
                <hr />
                <slot />
            </div>
        </main>

        <!-- <style>
         
        </style> -->
    </body>
</html>
